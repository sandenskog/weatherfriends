<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
<% if (valid) { %>
    <title><%= senderName %> invited you to FriendsCast</title>
    <meta property="og:title" content="<%= senderName %> invited you to FriendsCast">
    <meta property="og:description" content="See the weather where <%= senderName %> is in <%= senderCity %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://friendscast.sandenskog.se/invite/<%= token %>">
    <meta property="og:image" content="https://friendscast.sandenskog.se/og-preview.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
<% } else { %>
    <title>FriendsCast - Weather + Friends</title>
    <meta property="og:title" content="FriendsCast - Weather + Friends">
    <meta property="og:description" content="See the weather where your friends are. Stay connected through sun, rain, and everything in between.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://friendscast.sandenskog.se">
    <meta property="og:image" content="https://friendscast.sandenskog.se/og-preview.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
<% } %>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
            background: linear-gradient(160deg, #FFF5EE 0%, #FFE8D6 50%, #FFDAB9 100%);
            color: #333;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }
        .card {
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 8px 40px rgba(255, 107, 138, 0.15), 0 2px 8px rgba(0,0,0,0.05);
            max-width: 480px;
            width: 100%;
            padding: 2.5rem 2rem;
            text-align: center;
        }
        .app-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #FF6B8A 0%, #FF8E6B 100%);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 1.8rem;
            font-weight: 700;
            color: #fff;
            box-shadow: 0 4px 16px rgba(255, 107, 138, 0.3);
        }
        h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #222;
            margin-bottom: 0.5rem;
            line-height: 1.3;
        }
        .subtitle {
            font-size: 1rem;
            color: #666;
            margin-bottom: 1.5rem;
            line-height: 1.5;
        }
        .sender-info {
            background: linear-gradient(135deg, #FFF0EB 0%, #FFE4D6 100%);
            border-radius: 16px;
            padding: 1.25rem;
            margin-bottom: 1.5rem;
        }
        .sender-info .name {
            font-size: 1.2rem;
            font-weight: 600;
            color: #FF6B8A;
        }
        .sender-info .city {
            font-size: 0.9rem;
            color: #888;
            margin-top: 0.25rem;
        }
        .description {
            font-size: 0.95rem;
            color: #777;
            line-height: 1.6;
            margin-bottom: 2rem;
        }
        .app-store-btn {
            display: inline-block;
            background: linear-gradient(135deg, #FF6B8A 0%, #FF8E6B 100%);
            color: #fff;
            font-size: 1.1rem;
            font-weight: 600;
            padding: 0.9rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            border: none;
            cursor: pointer;
            box-shadow: 0 4px 16px rgba(255, 107, 138, 0.35);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .app-store-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(255, 107, 138, 0.45);
        }
        .app-store-btn:active {
            transform: translateY(0);
        }
        .platform-note {
            font-size: 0.85rem;
            color: #aaa;
            margin-top: 1rem;
        }
        .platform-note a {
            color: #FF8E6B;
            text-decoration: none;
        }
        .invalid-message {
            color: #999;
            font-size: 1rem;
            margin-bottom: 1.5rem;
        }
        .footer-link {
            display: block;
            margin-top: 2rem;
            font-size: 0.85rem;
            color: #bbb;
        }
        .footer-link a {
            color: #FF8E6B;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="app-icon">FC</div>

<% if (valid) { %>
        <h1><%= senderName %> invited you to FriendsCast</h1>
        <p class="subtitle">See the weather where your friends are</p>

        <div class="sender-info">
            <div class="name"><%= senderName %></div>
            <% if (senderCity) { %>
            <div class="city"><%= senderCity %></div>
            <% } %>
        </div>

        <p class="description">
            FriendsCast lets you see the weather where your friends live.
            Stay connected through sun, rain, and everything in between.
        </p>

    <% if (isIOS) { %>
        <button class="app-store-btn" onclick="redirectToAppStore('<%= token %>', '<%= appStoreUrl %>')">
            Get FriendsCast
        </button>
    <% } else if (isAndroid) { %>
        <p class="platform-note">
            FriendsCast is currently available for iPhone only.<br>
            <a href="<%= appStoreUrl %>">View on the App Store</a>
        </p>
    <% } else { %>
        <p class="platform-note">
            FriendsCast is currently available for iPhone only.<br>
            <a href="<%= appStoreUrl %>">View on the App Store</a>
        </p>
    <% } %>

<% } else { %>
        <h1>FriendsCast</h1>
        <p class="invalid-message">This invite link is no longer valid.</p>
        <a class="app-store-btn" href="https://apps.apple.com/app/id6760045281">
            Get FriendsCast
        </a>
<% } %>

        <span class="footer-link">
            <a href="/">friendscast</a>
        </span>
    </div>

<% if (valid) { %>
    <script>
    function redirectToAppStore(token, appStoreUrl) {
        var clipboardText = 'friendscast-invite:' + token + ':' + Math.floor(Date.now() / 1000);

        // Try modern clipboard API first
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(clipboardText).then(function() {
                setTimeout(function() {
                    window.location.href = appStoreUrl;
                }, 500);
            }).catch(function() {
                fallbackCopy(clipboardText, appStoreUrl);
            });
        } else {
            fallbackCopy(clipboardText, appStoreUrl);
        }
    }

    function fallbackCopy(text, appStoreUrl) {
        var textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();
        try {
            document.execCommand('copy');
        } catch (e) {
            // Clipboard copy failed silently
        }
        document.body.removeChild(textarea);
        setTimeout(function() {
            window.location.href = appStoreUrl;
        }, 500);
    }
    </script>
<% } %>
</body>
</html>
