rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Alla autentiserade användare kan läsa profiler (behövs för vänner i fas 3)
      allow read: if request.auth != null;
      // Användare kan bara skriva sin egen profil
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
